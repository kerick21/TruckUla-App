# Environment
NODE_ENV=development

# Database
DATABASE_URL=postgresql://waze_user:waze_password@localhost:5432/waze_db
MONGODB_URL=mongodb://waze_user:waze_password@localhost:27017/waze_db
REDIS_URL=redis://localhost:6379
CLICKHOUSE_URL=http://localhost:8123

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=waze-group

# Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token

# Auth
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRY=7d
OAUTH_CLIENT_ID=your_oauth_client_id
OAUTH_CLIENT_SECRET=your_oauth_client_secret

# Push Notifications
FCM_SERVER_KEY=your_fcm_server_key
APNS_CERTIFICATE=your_apns_certificate
APNS_KEY=your_apns_key

# API
API_PORT=3000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3001

# Frontend
VITE_API_URL=http://localhost:3000
VITE_MAPS_API_KEY=your_google_maps_api_key
VITE_MAPBOX_TOKEN=your_mapbox_access_token

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3002

# AWS (si usas AWS)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# GCP (si usas GCP)
GCP_PROJECT_ID=your_project_id
GCP_CREDENTIALS=your_credentials_json
