{
  "buildCommand": "echo 'No build needed'",
  "outputDirectory": "frontend/web",
  "public": true,
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/(?!app\\.js|styles\\.css|.*\\.png|.*\\.jpg|.*\\.ico|.*\\.json)(.*)",
      "destination": "/index.html"
    }
  ]
}
